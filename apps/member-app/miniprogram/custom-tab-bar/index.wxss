.tabbar {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 90;
  display: flex;
  padding: 12rpx 0 calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(255, 255, 255, 0.96);
  border-top: 1rpx solid #EAEAEA;
  box-shadow: 0 -2rpx 8rpx rgba(0, 0, 0, 0.03);
  backdrop-filter: blur(10px);
}
.tabbar-item {
  flex: 1;
  display: flex; flex-direction: column; align-items: center; gap: 6rpx;
  padding: 10rpx 0;
}
.tabbar-icon {
  width: 60rpx; height: 60rpx; border-radius: 18rpx;
  display: flex; align-items: center; justify-content: center;
  transition: background 0.2s;
}
.tabbar-icon--active { background: #F1F0EC; }
.tabbar-label { font-size: 20rpx; color: #9B9A97; }
.tabbar-label--active { color: #111111; font-weight: 600; }
