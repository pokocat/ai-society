/**
 * 自定义 TabBar 样式。
 * 图标为内联 SVG data-URI（**不依赖任何自定义组件**）——自定义 tabBar 在
 * lazyCodeLoading 按需注入下引用全局组件会渲染成空白栏，这里彻底规避。
 */
.tabbar {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 90;
  display: flex;
  padding: 10rpx 0 calc(14rpx + env(safe-area-inset-bottom));
  background: #FFFFFF;
  border-top: 1rpx solid #EAEAEA;
}
.tabbar-item {
  flex: 1;
  display: flex; flex-direction: column; align-items: center; gap: 6rpx;
  padding: 8rpx 0;
}
.tabbar-icon {
  width: 56rpx; height: 56rpx; border-radius: 16rpx;
  display: flex; align-items: center; justify-content: center;
  transition: background 0.18s;
}
.tabbar-item--active .tabbar-icon { background: #F1F0EC; }
/* 图标本体：36rpx 见方的背景图 */
.ti {
  width: 36rpx; height: 36rpx;
  background-size: 100% 100%; background-repeat: no-repeat;
}
.tabbar-label { font-size: 20rpx; color: #9B9A97; }
.tabbar-item--active .tabbar-label { color: #111111; font-weight: 600; }

