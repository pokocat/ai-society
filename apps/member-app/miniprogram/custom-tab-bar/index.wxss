.tabbar {
  position: fixed; left: 0; right: 0; bottom: 0; z-index: 90;
  display: flex;
  padding: 12rpx 0 calc(16rpx + env(safe-area-inset-bottom));
  background: rgba(14, 17, 32, 0.97);
  border-top: 1rpx solid rgba(255, 255, 255, 0.07);
  backdrop-filter: blur(10px);
}
.tabbar-item {
  flex: 1;
  display: flex; flex-direction: column; align-items: center; gap: 6rpx;
  padding: 10rpx 0;
}
.tabbar-icon {
  width: 60rpx; height: 60rpx; border-radius: 22rpx;
  display: flex; align-items: center; justify-content: center;
  transition: background 0.2s;
}
.tabbar-icon--active { background: rgba(67, 97, 238, 0.15); }
.tabbar-label { font-size: 20rpx; color: #64748b; }
.tabbar-label--active { color: #4361ee; font-weight: 600; }
