.hd--home { padding-bottom: 8rpx; }
.top-row { margin-bottom: 36rpx; }
.greet-row { gap: 12rpx; }
.greet { font-size: 32rpx; font-weight: 600; color: #e2e8f0; }
.sub-row { gap: 10rpx; margin-top: 8rpx; }
.bell-wrap { position: relative; }
.bell { width: 68rpx; height: 68rpx; border-radius: 50%; background: #1a2640; }

.hero-flush { margin: 0 0 30rpx; }
.hero-top { align-items: flex-start; margin-bottom: 36rpx; }
.hero-id-row { gap: 10rpx; margin-bottom: 8rpx; }
.hero-id { font-size: 22rpx; font-weight: 600; color: #ffffff; }
.hero-name { font-size: 38rpx; font-weight: 700; color: #ffffff; }
.hero-bottom { align-items: flex-end; }
.hero-k { font-size: 22rpx; color: rgba(255, 255, 255, 0.65); }
.hero-v { font-size: 26rpx; font-weight: 500; color: #ffffff; }
.hero-v--strong { font-size: 30rpx; font-weight: 700; }
.ta-r { text-align: right; }

.mt-4 { margin-top: 4rpx; }
.mt-6 { margin-top: 6rpx; }
.mt-10 { margin-top: 10rpx; }
.mt-16 { margin-top: 16rpx; }
.mt-20 { margin-top: 20rpx; }
.mt-30 { margin-top: 30rpx; }
.fw-500 { font-weight: 500; }

.course-row { gap: 20rpx; }
.dots { gap: 10rpx; padding: 10rpx 0 10rpx 16rpx; }

.teacher-card { gap: 26rpx; }
.todo-row { gap: 22rpx; }
.card--list { padding-top: 6rpx; padding-bottom: 6rpx; }

.invite-title-row { gap: 12rpx; }
.invite-btns { gap: 22rpx; margin-top: 28rpx; }
.invite-share-btn { flex: 1; font-size: 28rpx; padding: 20rpx 0; }

.sheet-teacher {
  gap: 22rpx; margin-top: 30rpx; padding: 24rpx;
  border-radius: 30rpx; background: #1a2640;
}
.notify-empty { padding: 30rpx 0; }
.notify-item {
  gap: 20rpx; padding: 22rpx; border-radius: 24rpx;
  background: #1a2640; margin-bottom: 16rpx; align-items: flex-start;
}
.notify-dot { width: 14rpx; height: 14rpx; border-radius: 50%; background: #4361ee; margin-top: 10rpx; flex-shrink: 0; }
