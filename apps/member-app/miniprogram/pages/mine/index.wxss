.profile-hd { text-align: center; padding-top: 56rpx; }
.avatar-center { margin: 0 auto; }
.name-row { margin-top: 24rpx; gap: 6rpx; }
.profile-name { font-size: 36rpx; font-weight: 700; color: #111111; letter-spacing: -0.5rpx; }
.name-edit { opacity: 0.7; }
.tags-row { gap: 16rpx; margin-top: 24rpx; flex-wrap: wrap; }

.card--list { padding-top: 6rpx; padding-bottom: 6rpx; }
.empty-row { padding: 30rpx 0; }
.info-k { font-size: 24rpx; color: #9B9A97; }
.fw-500 { font-weight: 500; }
.fw-600 { font-weight: 600; }
.ta-r { text-align: right; }
.ta-l { text-align: left; }

.order-row { gap: 20rpx; }
.order-icon { background: #E1F3FE; }
.order-amt { font-size: 28rpx; font-weight: 700; color: #346538; }

.menus { margin: 6rpx 40rpx 0; }
.menu-item {
  gap: 22rpx; background: #FFFFFF; border-radius: 20rpx;
  border: 1rpx solid #EAEAEA;
  padding: 26rpx 28rpx; margin-bottom: 16rpx;
}
/* button 版菜单行：抹平原生按钮默认样式 */
.menu-item--btn {
  display: flex; align-items: center; width: 100%; box-sizing: border-box;
  font-size: 26rpx; font-weight: 400; line-height: 1.6; color: #2F3437;
}
.menu-item--btn::after { border: none; }

.faq-head { gap: 10rpx; }
.faq-item { padding: 22rpx 0; }
.faq-item--line { border-bottom: 1rpx solid #F0EFEC; }

.logout-wrap { margin: 20rpx 40rpx 0; }

.mt-4 { margin-top: 4rpx; }
.mt-6 { margin-top: 6rpx; }
.mt-10 { margin-top: 10rpx; }
.mt-12 { margin-top: 12rpx; }
.mt-26 { margin-top: 26rpx; }
.mt-30 { margin-top: 30rpx; }
