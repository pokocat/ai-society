.prog-row { gap: 24rpx; margin-top: 16rpx; }
.prog-done { font-size: 24rpx; font-weight: 600; color: #346538; }
.prog-points { font-size: 24rpx; color: #956400; }
.mt-22 { margin-top: 22rpx; }

.empty-card { text-align: center; padding: 70rpx 32rpx; }

.task-card--done {
  opacity: 0.8;
  background: #F5F9F5;
  border-color: #D9E6DA;
}
.task-row { gap: 22rpx; align-items: flex-start; }
.task-check { margin-top: 2rpx; }
.task-title { font-size: 28rpx; font-weight: 600; color: #2F3437; }
.task-title--done { color: #9B9A97; text-decoration: line-through; }
.task-meta { gap: 16rpx; margin-top: 14rpx; flex-wrap: wrap; }
.meta-clock { gap: 8rpx; }
