.pt-30 { padding-top: 30rpx; }
.ta-c { text-align: center; }

.code-cap { gap: 10rpx; }
.code-cap-text { font-size: 24rpx; color: rgba(255, 255, 255, 0.75); }
.code-wrap { margin: 26rpx 0; }
/* 邀请码 16 字符需单行放下（卡片内宽约 594rpx），56rpx 会折行 */
.code { font-size: 44rpx; font-weight: 700; color: #ffffff; letter-spacing: 4rpx; white-space: nowrap; }
.hero-btns { gap: 20rpx; }
.share-btn { flex: 1; background: rgba(255, 255, 255, 0.92); color: #4361ee; font-weight: 700; }
.copy-btn { flex: 1; background: rgba(255, 255, 255, 0.16); color: #ffffff; border: 1rpx solid rgba(255, 255, 255, 0.35); }
.mock-note { font-size: 20rpx; color: rgba(255, 255, 255, 0.55); }

.mt-0 { margin-top: 0; }
.mt-8 { margin-top: 8rpx; }
.mt-18 { margin-top: 18rpx; }
.mt-22 { margin-top: 22rpx; }

.tree-head { gap: 12rpx; }
.tree-row { padding-top: 18rpx; padding-bottom: 18rpx; border-bottom: 1rpx solid rgba(255, 255, 255, 0.07); }
.tree-name { gap: 16rpx; }
.tree-chip {
  width: 52rpx; height: 52rpx; border-radius: 18rpx;
  font-size: 24rpx; font-weight: 600; flex-shrink: 0;
}
.foot-note { margin: 0 40rpx; }
